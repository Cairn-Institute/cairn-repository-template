# Copy this file to .env and fill in real values locally.
# Never commit a real .env file or real secrets.

APP_NAME=cairn-repository-template
APP_ENV=development
APP_URL=http://localhost:3000

# Database connection (placeholder values only)
DATABASE_URL=postgres://user:password@localhost:5432/app_dev

# Authentication (placeholder values only)
AUTH_CLIENT_ID=replace-me
AUTH_CLIENT_SECRET=replace-me

# Third-party services (placeholder values only)
API_BASE_URL=https://api.example.com
API_KEY=replace-me
